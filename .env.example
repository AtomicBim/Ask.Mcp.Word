# Скопируйте в .env и заполните значения перед первым запуском:
#   cp .env.example .env

# UID/GID хоста — чтобы bind-mount'ы (word_files, logs) были доступны на запись.
# Получить значения: id -u  и  id -g
UID=1000
GID=1000

# ─── Транспорт MCP ──────────────────────────────────────────────────────────
# Эти переменные читаются word_document_server/main.py.
# Для развёртывания в docker-сети значения уже выставлены в docker-compose.yml,
# здесь их обычно переопределять не нужно.
#MCP_TRANSPORT=streamable-http
#MCP_HOST=0.0.0.0
#MCP_PORT=8018
#MCP_PATH=/mcp

# ─── Каталоги ───────────────────────────────────────────────────────────────
# Куда складываются пользовательские .docx внутри контейнера (это же CWD
# процесса). Bind-mount на хост — в docker-compose.yml.
WORD_FILES_PATH=/app/word_files

# Файл логов (внутри контейнера). Ротация — внешними средствами (logrotate
# на хосте или docker logging driver).
WORD_MCP_LOG_FILE=/app/logs/word-mcp.log
